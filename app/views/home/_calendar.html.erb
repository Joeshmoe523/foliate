<!-- Calendar Header -->
<div class="py-1 rounded-t-lg bg-gray-50 border-t border-x border-gray-300">
  <h3 class="text-lg font-semibold text-gray-800 text-center">
    <%= @current_month.strftime('%B %Y') %>
  </h3>
</div>

<!-- Calendar Grid -->
<div class="bg-white rounded-b-lg border border-gray-300 p-2">
  <!-- Day headers -->
  <div class="grid grid-cols-7 gap-0.5 mb-1">
    <% ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'].each do |day| %>
      <div class="text-center text-xs font-medium text-gray-500 py-1">
        <%= day %>
      </div>
    <% end %>
  </div>

  <!-- Calendar days -->
  <div class="grid grid-cols-7 gap-0.5">
    <% @calendar_data.each do |week| %>
      <% week.each do |day_data| %>
        <div class="h-8 flex items-center justify-center relative">
          <% if day_data[:is_current_month] %>
            <div class="w-6 h-6 flex items-center justify-center rounded-full transition-all duration-200 hover:scale-110">
              <% if day_data[:has_reflection] %>
                <!-- Leaf SVG Icon with Date Number -->
                <div class="relative">
                  <svg class="w-8 h-8 text-green-600" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M17 8C8 10 5.9 16.17 3.82 21.34l1.89.66.95-2.3c.48.17.98.3 1.34.3C19 20 22 3 22 3c-1 2-8 2.25-13 3.25S2 11.5 2 13.5s1.75 3.75 1.75 3.75S7 14 17 8z"/>
                  </svg>
                  <div class="absolute inset-0 flex items-center justify-center">
                    <span class="text-[10px] font-bold text-white drop-shadow-sm <%= day_data[:is_today] ? 'text-white' : 'text-bg-brand' %>">
                      <%= day_data[:day_number] %>
                    </span>
                  </div>
                </div>
              <% else %>
                <!-- Day number -->
                <span class="text-xs font-medium <%= day_data[:is_today] ? 'text-white' : 'text-gray-700' %>">
                  <%= day_data[:day_number] %>
                </span>
              <% end %>
            </div>
          <% else %>
            <div class="w-6 h-6 flex items-center justify-center rounded-full">
              <span class="text-xs font-medium text-gray-300">
                <%= day_data[:day_number] %>
              </span>
            </div>
          <% end %>
        </div>
      <% end %>
    <% end %>
  </div>
</div>

<!-- Reflection Stats -->
<div class="mt-4 bg-gray-50 rounded-lg p-3">
  <h4 class="text-sm font-medium text-gray-700 mb-2">This Month</h4>
  <div class="flex items-center justify-between text-sm">
    <span class="text-gray-600">Total reflections:</span>
    <span class="font-semibold text-gray-900">
      <%= @reflection_stats[:total_reflections] %>
    </span>
  </div>
  <div class="flex items-center justify-between text-sm mt-1">
    <span class="text-gray-600">Reflection days:</span>
    <span class="font-semibold text-gray-900">
      <%= @reflection_stats[:reflection_days] %>
    </span>
  </div>
</div>
