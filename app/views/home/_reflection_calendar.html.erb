<div class="w-full overflow-hidden">
  <%= month_calendar(class: "w-full", table_class: "w-full", prev_text: "", next_text: "") do |date| %>
    <div class="calendar-day relative w-full h-10 flex items-center justify-center">
      <% if @reflections[date]&.any? %>
        <!-- Date with reflection - show leaf icon with number -->
        <div class="relative flex items-center justify-center w-7 h-7">
          <!-- Leaf icon background -->
          <svg class="absolute inset-0 w-full h-full text-bg-brand" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17 8C8 10 5.9 16.17 3.82 21.34l1.89.66.95-2.3c.48.17.98.3 1.34.3C19 20 22 3 22 3c-1 2-8 2.25-13 3.25S2 11.5 2 13.5s1.75 3.75 1.75 3.75S7 14 17 8z"/>
          </svg>
          <!-- Date number -->
          <span class="relative z-10 text-xs font-semibold text-white drop-shadow-sm">
            <%= date.day %>
          </span>
        </div>
      <% else %>
        <!-- Regular date - just number in circle -->
        <div class="w-7 h-7 rounded-full bg-white border border-gray-200 flex items-center justify-center hover:bg-gray-300 transition-colors">
          <span class="text-xs font-medium text-gray-700">
            <%= date.day %>
          </span>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
