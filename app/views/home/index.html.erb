<div class="h-full w-full flex justify-center py-8">
  <div class="bg-white rounded-2xl shadow-2xl p-8 max-w-lg w-full">
    <!-- Alpha Users Section -->
    <div class="text-center mb-8">
      <div class="mb-4">
        <svg class="w-16 h-16 text-green-600 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
        <h1 class="text-3xl font-bold text-gray-900 mb-2">Terra Incognita</h1>
        <p class="text-gray-600">Your journey to professional growth starts here</p>
      </div>
      
      <div class="bg-green-50 border border-green-200 rounded-lg p-4 mb-6">
        <h2 class="text-lg font-semibold text-green-800 mb-2">Alpha Users</h2>
        <p class="text-sm text-green-700 mb-4">Early access to our career development platform</p>
        <%= link_to "Sign In", new_user_session_path, class: "inline-flex items-center px-6 py-3 bg-green-600 hover:bg-green-700 text-white font-medium rounded-lg text-sm transition-colors duration-200 focus:ring-4 focus:outline-none focus:ring-green-300" %>
      </div>
    </div>

    <!-- Divider -->
    <div class="relative mb-8">
      <div class="absolute inset-0 flex items-center">
        <div class="w-full border-t border-gray-300"></div>
      </div>
      <div class="relative flex justify-center text-sm">
        <span class="px-2 bg-white text-gray-500">or</span>
      </div>
    </div>

    <!-- Mailing List Section -->
    <div class="text-center">
      <h3 class="text-lg font-semibold text-gray-900 mb-2">Stay Updated</h3>
      <p class="text-sm text-gray-600 mb-4">Join our mailing list to be notified when we launch</p>
      
      <form class="space-y-3">
        <div>
          <input type="email" 
                placeholder="Enter your email address" 
                class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-green-500 text-sm transition-colors duration-200"
                required>
        </div>
        <button type="submit" 
                class="w-full px-6 py-3 bg-gray-800 hover:bg-gray-900 text-white font-medium rounded-lg text-sm transition-colors duration-200 focus:ring-4 focus:outline-none focus:ring-gray-300">
          Join Mailing List
        </button>
      </form>
      
      <p class="text-xs text-gray-500 mt-4">
        We'll only use your email to send you updates about our launch. No spam, ever.
      </p>
    </div>
  </div>
</div>