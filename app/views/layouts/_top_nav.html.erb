<nav class="sticky top-0 z-30 w-full px-5 py-1.5 flex items-center justify-between">
  <div class="flex items-center">
    <div class="flex-shrink-0">
      <svg class="w-6 h-6 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
      </svg>
    </div>
    <div class="flex-1 min-w-0 sidebar-text transition-opacity duration-300 ps-2 border-r border-gray-400" data-sidebar-target="text">
      <h2 class="text-base font-semibold text-gray-200 truncate pr-6">FoliateAI</h2>
    </div>
    <div class="ps-4">
      <% if content_for?(:breadcrumbs) %>
        <%= yield :breadcrumbs %>
      <% end %>
    </div>
  </div>

  <% if current_user %>
    <div class="flex items-center gap-4">
      <button type="button" data-modal-target="logout-modal" data-modal-toggle="logout-modal" class="group flex justify-center p-2 relative text-gray-500 rounded cursor-pointer hover:text-gray-900 hover:bg-gray-100" data-tooltip-target="logout-tooltip" data-tooltip-placement="left">
        <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
          <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 12H8m12 0-4 4m4-4-4-4M9 4H7a3 3 0 0 0-3 3v10a3 3 0 0 0 3 3h2"/>
        </svg>
        <div id="logout-tooltip" role="tooltip" class="fixed z-[60] invisible inline-block px-3 py-2 text-sm font-medium text-rp-base-text transition-opacity duration-300 bg-rp-highlight-dark rounded-lg shadow-sm opacity-0 tooltip" data-tooltip-placement="left">
          Logout
          <div class="tooltip-arrow" data-popper-arrow></div>
        </div>
      </button>
    </div>
  <% else %>
    <div class="flex items-center gap-4">
      <%= link_to "Sign in", new_user_session_path, class: "text-white bg-green-600 hover:bg-green-800 focus:ring-4 focus:outline-none focus:ring-green-300 font-medium rounded-lg text-sm inline-flex items-center px-4 py-2 text-center me-2" %>
    </div>
  <% end %>
</nav>