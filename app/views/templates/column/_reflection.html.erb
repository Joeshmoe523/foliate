<%= link_to reflection_path(reflection), 
    data: { 
      turbo_frame: "growth_plan_main_content",
      controller: "reflection",
      action: "click->reflection#select"
    },
    class: "block #{'border-l-2 border-blue-400 bg-blue-50' if current_reflection?(reflection)}" do %>
  <div class="hover:bg-gray-50 cursor-pointer border-l-2 border-transparent hover:border-blue-400">
    <div class="px-4 py-3">
      <div class="flex items-center justify-between">
        <div class="flex items-center min-w-0">
          <div class="flex-shrink-0">
            <svg class="h-4 w-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
            </svg>
          </div>
          <div class="ml-3 min-w-0">
            <h3 class="text-sm font-medium text-gray-700 truncate"><%= reflection.title %></h3>
          </div>
        </div>
      </div>
    </div>
  </div>
<% end %>