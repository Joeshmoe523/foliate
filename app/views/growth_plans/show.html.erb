<% content_for :scrollable_content do %>

  <div class="flex flex-col justify-center pb-4">
    <div class="w-full px-4 pt-4">
      <!-- Action Buttons -->
      <div class="flex space-x-3">
        <%= link_to "Plan Details", 
            growth_plan_path(@growth_plan), 
            data: { turbo_frame: "growth_plan_main_content" },
            class: "flex-1 bg-white border border-gray-300 text-gray-700 hover:bg-gray-50 focus:ring-4 focus:ring-brand-inverse font-medium rounded-lg text-sm px-4 py-2 focus:outline-none cursor-pointer text-center block" %>
        
        <button onclick="Turbo.visit('<%= new_reflection_growth_plan_path(@growth_plan) %>', { frame: 'growth_plan_main_content' })"
                class="flex-1 bg-brand-active text-white hover:bg-brand-hover focus:ring-4 focus:ring-brand-inverse font-medium rounded-lg text-sm px-4 py-2 focus:outline-none cursor-pointer text-center block">
          New Reflection
        </button>
      </div>
    </div>
  </div>
  
  <%= render "growth_plans/reflections_list", growth_plan: @growth_plan %>
<% end %>

<% content_for :column_content do %>
  <%= render "templates/scrollable", scrollable_content: :scrollable_content %>
<% end %>

<% content_for :page_content do %>
  <div class="flex flex-col h-full w-full bg-gray-100">
    <!-- Navigation Header -->
    <div class="pt-8 px-6">
      <%= link_to growth_plans_path, class: "inline-flex items-center text-gray-600 hover:text-gray-900" do %>
        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
        All Growth Plans
      <% end %>
    </div>

    <!-- Main Content Area -->
    <div class="flex-1 flex min-h-0">
      <!-- Left Column - Main Content (2/3 width) -->
      <div class="w-full h-full min-h-0">
        <div class="px-8 pt-4">
          <!-- Project Title & Actions -->
          <div class="flex items-center justify-between mb-2">
            <h1 class="text-3xl font-bold text-gray-900"><%= @growth_plan.title %></h1>
            <div class="flex items-center space-x-2">
              <!-- Three dots menu -->
              <button class="p-2 text-gray-500 hover:text-gray-700">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 8c1.1 0 2-.9 2-2s-.9-2-2-2-2 .9-2 2 .9 2 2 2zm0 2c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zm0 6c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2z"/>
                </svg>
              </button>
              <!-- Star icon -->
              <button class="p-2 text-yellow-500 hover:text-yellow-600">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                </svg>
              </button>
            </div>
          </div>

          <!-- Project Description -->
          <div class="mb-8">
            <p class="text-gray-700 text-base leading-relaxed font-light">
              <%= @growth_plan.summary.present? ? @growth_plan.summary : "No description available for this growth plan." %>
            </p>
          </div>

          <!-- Main Content Section -->
          <%= turbo_frame_tag "growth_plan_main_content", class: "flex flex-col h-full" do %>
            <%= render "growth_plans/main_content", growth_plan: @growth_plan %>
          <% end %>
        </div>
      </div>

       <!-- Right Column - set width -->
       <div class="w-40 h-full min-h-0">
         <div class="p-6">

         </div>
       </div>
    </div>
  </div>
<% end %>

<div class="flex h-full w-full overflow-hidden">
  <div class="flex flex-col bg-white h-full w-full rounded-tl-xl overflow-hidden min-h-0">

    <div class="flex-1 w-full flex min-h-0 overflow-hidden">
      <!-- Left column content -->
       <div class="w-80 border-r border-gray-200 h-full flex flex-col overflow-y-auto min-h-0">
         <%= yield :column_content %>
       </div>

      <!-- Right column content -->
      <div class="flex-1 h-full overflow-y-auto min-h-0">
        <%= yield :page_content %>
      </div>
    </div>
  </div>
</div>
