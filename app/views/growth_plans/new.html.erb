<% content_for :page_content do %>
  <div class="flex flex-col h-full w-[90%] mx-auto">
    <!-- Form section -->
    <div class="flex-1 flex items-center justify-center">
      <div class="w-full max-w-md">
        <h1 class="text-3xl font-semibold text-gray-900 mb-6 text-left">Create a Growth Plan</h1>
        <%= form_with(model: @growth_plan, local: true, class: "space-y-6") do |form| %>
          <!-- Title field -->
          <div>
            <%= form.label :title, "What are you working on?", class: "block text-sm font-medium text-gray-700 mb-2" %>
            <%= form.text_field :title, 
                placeholder: "Name your Growth Plan", 
                class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-active focus:border-brand-active" %>
          </div>

          <!-- Summary field -->
          <div>
            <%= form.label :summary, "How you are trying to grow?", class: "block text-sm font-medium text-gray-700 mb-2" %>
            <%= form.text_area :summary, 
                placeholder: "Describe what you want to learn, what you want to achieve, what you want to do, etc...", 
                rows: 4,
                class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-active focus:border-brand-active" %>
          </div>

          <!-- Action buttons -->
          <div class="flex justify-end space-x-3 pt-4">
            <%= link_to "Cancel", growth_plans_path, 
                class: "px-4 py-2 border border-gray-300 rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-gray-500" %>
            <%= form.submit "Create Growth Plan", 
                class: "px-4 py-2 bg-brand-active text-white rounded-md hover:bg-brand-hover focus:outline-none focus:ring-2 focus:ring-brand-active" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
<% end %>

<div class="flex h-full w-full overflow-hidden">
  <div class="flex flex-col bg-gray-100 h-full w-full rounded-tl-xl overflow-hidden min-h-0">
    <%= yield :page_content %>
  </div>
</div>
